{
    "name": "@ldystudio/react-graphql-query",
    "version": "1.1.0",
    "description": "Definition-driven GraphQL query helpers for React and React Native built on TanStack Query and graphql-request",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "sideEffects": false,
    "scripts": {
        "build": "rm -rf dist dist-types && bun run typecheck && rolldown -c && bun scripts/finalize-dts.ts",
        "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json --noEmit",
        "test": "bun test",
        "lint": "biome check .",
        "lint:fix": "biome check --write .",
        "format": "biome format --write .",
        "prepublishOnly": "bun run lint && bun test && bun run build"
    },
    "keywords": [
        "react",
        "react-native",
        "graphql",
        "graphql-request",
        "tanstack-query",
        "react-query"
    ],
    "author": "ldystudio",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ldystudio/react-graphql-query.git"
    },
    "peerDependencies": {
        "@tanstack/react-query": ">=5.0.0",
        "graphql-request": ">=6.1.0",
        "react": ">=18.0.0"
    },
    "dependencies": {
        "graphql": "^16.11.0"
    },
    "devDependencies": {
        "@biomejs/biome": "^2.4.4",
        "@happy-dom/global-registrator": "^20.1.0",
        "@tanstack/react-query": "^5.90.21",
        "@testing-library/react": "^16.3.0",
        "@types/bun": "^1.3.0",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "graphql-request": "^6.1.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "rolldown": "^1.0.0-rc.3",
        "rolldown-plugin-dts": "^0.22.5",
        "typescript": "^5.9.3"
    }
}
